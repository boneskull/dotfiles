#!/usr/bin/env bash

# modified from https://github.com/nicknisi/dotfiles/blob/e15dc3c0a0fa6e137dee615eb7a5e224bf6d2355/bin/git-create-worktree
# glamorized with https://github.com/charmbracelet/gum

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

if ! command -v gum &>/dev/null; then
  echo >&2 "gum is not installed."
  echo >&2 "See https://github.com/charmbracelet/gum#installation"
  exit 1
fi

function usage {
  cat <<EOF
Usage: $(basename "${BASH_SOURCE[0]}") [-h] [-v] [-B <base>] [-C] [-d <dir>] [<branch>] [path]

Create a new worktree with the specified branch name at the given path.
Run without arguments for interactive mode (requires a TTY).

Arguments:

  <branch>                    The branch to create or use
  [path]                      The directory for the worktree (optional; auto-generated from branch if omitted)

Options:

  -h, --help                  Print this help and exit
  -v, --verbose               Print script debug info
  -B, --base <ref>            Base branch for new worktree (default: HEAD; current branch in interactive mode)
  -C, --create-upstream       Create/set upstream branch on origin
  -d, --worktree-dir <dir>    Parent directory for worktrees (default: .worktrees)
  --no-color                  Disable color output

Example:

  git create-worktree                            # interactive mode
  git create-worktree boneskull/my-feature
  git create-worktree -d worktrees feat/gnarly-stuff
  git create-worktree my-branch my-custom-path
EOF
  exit
}

function cleanup {
  trap - SIGINT SIGTERM ERR EXIT
}

function die {
  gum log --level fatal "$1"
  exit "${2-1}"
}

# Sanitize a string for use as a filesystem path.
# Handles each path component separately, preserving:
#   - Leading dots (for hidden dirs like .worktrees)
#   - Slashes (path separators)
#   - Parent dir references (../)
# Each component is transliterated to ASCII, non-alphanumeric chars replaced
# with hyphens, leading/trailing hyphens stripped, and lowercased.
# Based on https://gist.github.com/oneohthree/f528c7ae1e701ad990e6
function slugify {
  local input="$1"
  local result=""
  local IFS='/'

  if [[ "$input" =~ \.\.[^/] ]]; then
    die "Invalid path '$input': '..' looks like you screwed up the path"
  fi

  read -ra components <<< "$input"
  for component in "${components[@]}"; do
    local prefix=""

    if [[ "$component" == "." || "$component" == ".." ]]; then
      :
    elif [[ "$component" == .* ]]; then
      prefix="."
      component="${component#.}"
      if [[ -n "$component" ]]; then
        component="$(iconv -t ascii//TRANSLIT <<< "$component" | sed -E 's/[^a-zA-Z0-9]+/-/g; s/^-+|-+$//g' | tr '[:upper:]' '[:lower:]')"
      fi
    elif [[ -n "$component" ]]; then
      component="$(iconv -t ascii//TRANSLIT <<< "$component" | sed -E 's/[^a-zA-Z0-9]+/-/g; s/^-+|-+$//g' | tr '[:upper:]' '[:lower:]')"
    fi

    if [[ -n "$result" ]]; then
      result="$result/"
    fi
    result="$result$prefix$component"
  done

  echo "$result"
}

function run_command {
  local message=$1
  shift
  if ! gum spin --spinner dot --title "$message" -- "$@"; then
    gum log --level error "$message"
    exit 1
  fi
  gum log --level info "$message"
}

function interactive_prompts {
  branch=$(gum input --placeholder "e.g., feat/my-feature" --header "Branch name")
  [[ -z "$branch" ]] && die "Branch name is required"

  # In interactive mode, default to current branch name instead of "HEAD"
  if [[ "$base" == "HEAD" ]]; then
    base=$(git branch --show-current 2>/dev/null || echo "HEAD")
  fi
  base=$(gum input --value "$base" --placeholder "Base ref" --header "Base branch or ref")
  [[ -z "$base" ]] && base="HEAD"

  local default_path
  default_path="$(slugify "$worktree_dir")/$(slugify "$branch")"
  worktree=$(gum input --value "$default_path" --placeholder "Path" --header "Worktree path")
  [[ -z "$worktree" ]] && worktree="$default_path"

  if gum confirm "Create/set upstream branch on origin?"; then
    create_upstream=1
  fi
}

function parse_params {
  create_upstream=0
  base='HEAD'
  worktree_dir='.worktrees'
  branch=''
  worktree=''

  while :; do
    case "${1-}" in
    -h | --help) usage ;;
    -v | --verbose) set -x ;;
    --no-color) export NO_COLOR=1 ;;
    -C | --create-upstream) create_upstream=1 ;;
    -B | --base)
      base="${2-}"
      shift
      ;;
    -d | --worktree-dir)
      worktree_dir="${2-}"
      shift
      ;;
    -?*) die "Unknown option: $1" ;;
    *) break ;;
    esac
    shift
  done

  local args=("$@")
  [[ ${#args[@]} -gt 2 ]] && die "Too many arguments. Run with -h for usage."

  if [[ ${#args[@]} -ge 1 ]]; then
    branch="${args[0]}"

    if [[ ${#args[@]} -eq 2 ]]; then
      local provided_path="${args[1]}"
      local dir_part base_part
      dir_part="$(dirname "$provided_path")"
      base_part="$(basename "$provided_path")"
      base_part="$(slugify "$base_part")"

      if [[ "$dir_part" == "." ]]; then
        worktree="$base_part"
      else
        worktree="$dir_part/$base_part"
      fi
    fi
  fi

  return 0
}

function update_remote {
  local branch="$1"
  [ $create_upstream -eq 0 ] && return 0

  if [[ -z "$(git ls-remote --heads origin "$branch")" ]]; then
    gum log --level info "Branch '$branch' does not exist on remote — creating"
    run_command "Creating remote branch $branch" git push -u origin "$branch"
  else
    gum log --level info "Branch '$branch' exists on remote — setting upstream"
    run_command "Setting upstream to origin/$branch" git branch --set-upstream-to="origin/$branch"
  fi
}

parse_params "$@"

if [[ -z "$branch" ]]; then
  if [[ -t 0 ]]; then
    interactive_prompts
  else
    die "No branch specified and stdin is not a TTY. Run with -h for usage."
  fi
fi

if [[ -z "$worktree" ]]; then
  worktree="$(slugify "$worktree_dir")/$(slugify "$branch")"
fi

if [[ -n "$(git branch --list "$branch")" ]]; then
  run_command "Creating worktree from existing branch: $branch" git worktree add "$worktree" "$branch"
else
  run_command "Creating worktree: $worktree" git worktree add -b "$branch" "$worktree" "$base"
fi

gum log --level info "Moving into worktree: $worktree"
cd "$worktree"
update_remote "$branch"

if [[ -f package.json ]]; then
  if [[ -f pnpm-lock.yaml ]]; then
    run_command "Installing dependencies (pnpm)" pnpm install --silent
  elif [[ -f yarn.lock ]]; then
    run_command "Installing dependencies (yarn)" yarn install --silent
  elif [[ -f bun.lockb ]] || [[ -f bun.lock ]]; then
    run_command "Installing dependencies (bun)" bun install
  else
    run_command "Installing dependencies (npm)" npm install --no-progress --silent
  fi
fi

gum log --level info "Done!"

#!/usr/bin/env zsh

# git-cleanup: A script to clean up local and remote branches in a Git
# repository.
#
# This script will detect local and remote branches that have been merged,
# rebased, or squashed into the trunk branch. The script will prompt the user
# for confirmation before deleting any branches.
#
# Usage: git cleanup [remote] [target] [prefix]
#
#  - remote: The remote repository (default: 'origin').
#  - target: The target branch to check against (default: the default branch of
#    the remote).
#  - prefix: The prefix for remote branches to consider (default:
#    user.branchPrefix config value or 'boneskull'); e.g., prefix 'boneskull'
#    will match branches like 'boneskull/feature-xyz'.
#
# To set the branch prefix globally, use `git config --global user.branchPrefix
# <prefix>` (without trailing slash)
#
# WARNING: not compatible with bash.

set -Eeuo pipefail

default_prefix='boneskull'

function log {
  print -P "$@" >&2
}

function ok {
  log "%F{green}✓%f $@"
}

function warn {
  log "%F{yellow}⚠%f $@"
}

function info {
  log "%F{blue}ℹ%f $@"
}

function error {
  log "%F{red}✗%f $@"
  exit 1
}

function em {
  echo "%F{yellow}$@%f"
}

function bold {
  echo "%F{red}$@%f"
}

# Gets the branch prefix from git config or uses the default.
function get_prefix {
  local prefix=$(git config get user.branchPrefix)
  if [[ -z $prefix ]]; then
    echo $default_prefix
  else
    echo $prefix
  fi
}

# Checks that the target branch exists on the remote.
function check_target {
  if ! git show-branch "${remote}/${target}" > /dev/null 2>&1; then
    error "No such branch: $(em "${remote}/${target}")"
  fi
}

# Determines the default branch of the remote repository
function default_branch {
  echo $(git rev-parse --abbrev-ref "${remote}/HEAD" | cut -c8-)
}

# Prompts the user for confirmation with a default response.
function confirm {
  local message="${1}"
  local default="${2:-N/y}"
  print -Pn "${message} "
  read -q "confirm?[${default}]? "
  echo
  if [[ ${confirm} =~ ^[Yy]$ ]]; then
    return 0
  else
    return 1
  fi
}

# Echoes how $1 landed in ${remote}/${target} ("merged"|"rebased"|"squashed"),
# or nothing if it has not. Used for both local and remote refs.
#
# Detection is ordered cheapest-first:
#   1. merged   — tip is reachable from upstream (merge commit or fast-forward)
#   2. rebased  — every commit's patch-id already exists upstream (git cherry all -)
#   3. squashed — collapsing the branch diff into one synthetic commit produces a
#                 patch-id that exists upstream
function merge_status {
  local branch="$1"
  local upstream="${remote}/${target}"

  # Merge commit or fast-forward: tip is reachable from upstream.
  if git merge-base --is-ancestor "$branch" "$upstream" 2>/dev/null; then
    echo merged
    return
  fi

  # Rebase: every commit's patch-id already exists upstream.
  local cherry
  cherry=$(git cherry "$upstream" "$branch" 2>/dev/null)
  if [[ -n $cherry ]] && ! grep -q '^+' <<<"$cherry"; then
    echo rebased
    return
  fi

  # Squash: collapse the branch's diff into one synthetic commit and
  # check whether that patch-id already exists upstream.
  # git commit-tree writes a dangling loose object; git gc reaps it harmlessly.
  local mb tree synth
  mb=$(git merge-base "$upstream" "$branch" 2>/dev/null) || return
  tree=$(git rev-parse "${branch}^{tree}" 2>/dev/null) || return
  synth=$(git commit-tree "$tree" -p "$mb" -m squash-probe 2>/dev/null) || return
  if git cherry "$upstream" "$synth" 2>/dev/null | grep -q '^-'; then
    echo squashed
  fi
}

# Removes local branches that have been merged into the target branch
# (via merge commit, rebase, or squash).
function cleanup_local_merged {
  local deleted=false
  local branches=($(git branch --list "${prefix}/*" --format='%(refname:short)'))
  if [[ -z $branches ]]; then
    info "No local branches found matching $(em "${prefix}/*")."
    return
  fi

  for branch in $branches; do
    local branch_status=$(merge_status "$branch")
    if [[ -n $branch_status ]]; then
      info "Local branch $(bold "${branch}") was $(em "${branch_status}") into $(em "${remote}/${target}")."
      confirm "Delete local branch $(bold "${branch}")" && {
        git branch -D "${branch}"
        deleted=true
      }
    fi
  done
  if [[ $deleted == true ]]; then
    ok "Deleted local branch(es) that have been merged into $(em "${remote}/${target}")."
  else
    info "Did not remove any local branches."
  fi
}

# Removes remote branches that have been merged into the target branch
# (via merge commit, rebase, or squash).
function cleanup_remote_merged {
  local deleted=false
  local branches=($(git branch -r --list "${remote}/${prefix}/*" --format='%(refname:lstrip=3)'))
  if [[ -z $branches ]]; then
    info "No remote branches found matching ${remote}/${prefix}*."
    return
  fi
  for branch in $branches; do
    local branch_status=$(merge_status "${remote}/${branch}")
    if [[ -n $branch_status ]]; then
      info "Remote branch $(bold "${remote}/${branch}") was $(em "${branch_status}") into $(em "${remote}/${target}")."
      confirm "Delete remote branch $(bold "${remote}/${branch}")" && {
        git push "${remote}" --delete "${branch}"
        deleted=true
      }
    fi
  done
  if [[ $deleted == true ]]; then
    ok "Deleted remote branch(es) that have been merged into $(em "${remote}/${target}")."
  else
    info "Did not remove any remote branches."
  fi
}

# Remote repository
remote=${1:-origin}
# "Trunk" branch on remote repository
target=${2:-$(default_branch)}
# Branch prefix
prefix=${3:-$(get_prefix)}

info "Using remote: $(em "${remote}"), trunk $(em "${target}"), and prefix $(em "${prefix}")."

# this will remove local branches that track deleted remote branches
git fetch --prune "${remote}"

check_target
cleanup_local_merged
cleanup_remote_merged

ok "Done."
